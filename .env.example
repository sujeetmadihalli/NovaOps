# NovaOps v2 - Environment Variables
# Copy this to .env and fill in your values.
# .env is gitignored -- never commit credentials.

# ── AWS Credentials ──────────────────────────────────────
# Option 1 (recommended): Run `aws configure` -- credentials stay in ~/.aws/
# Option 2: Set these directly (rotate regularly)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# ── Bedrock ──────────────────────────────────────────────
NOVA_MODEL_ID=us.amazon.nova-2-lite-v1:0
# AWS_BEARER_TOKEN_BEDROCK=

# ── NovaOps Core ─────────────────────────────────────────
NOVAOPS_USE_MOCK=true
# LOCAL_EVAL_MODE=false
# Optional hardening: if set, approval requires header X-NovaOps-Approval-Token
# NOVAOPS_APPROVAL_TOKEN=
# Optional: restrict CORS origins (JSON array or comma-separated list)
# NOVAOPS_CORS_ORIGINS=["http://localhost:8082","http://127.0.0.1:8082"]
# NOVAOPS_LOG_PATH=novaops.log
# HISTORY_DB_PATH=history.db

# ── Slack (Ghost Mode notifications) ─────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# SLACK_SIGNING_SECRET=

# ── Voice Escalation (Amazon Connect + Nova) ─────────────
NOVAOPS_VOICE_ESCALATION_ENABLED=true
NOVAOPS_VOICE_USE_MOCK=true
CRITICAL_SEVERITY_LEVELS=P1
CRITICAL_RISK_SCORE_THRESHOLD=85

# Amazon Connect (set these for real outbound calls)
# CONNECT_INSTANCE_ID=your-connect-instance-id
# CONNECT_CONTACT_FLOW_ID=your-contact-flow-id
# CONNECT_SOURCE_PHONE=+15551234567
# ONCALL_PHONE_NUMBER=+15559876543
# NOVAOPS_API_CALLBACK_URL=http://localhost:8082

# ── Docker / LocalStack ──────────────────────────────────
# DYNAMODB_ENDPOINT=http://localstack:4566
# S3_ENDPOINT=http://localstack:4566

# ── Jury GitHub Context ──────────────────────────────────
# SERVICE_REPO_MAP={"checkout-service":{"owner":"acme-inc","repo":"checkout-api"}}

# ── Knowledge Base (managed Bedrock KB) ──────────────────
# USE_BEDROCK_KB=false
# KNOWLEDGE_BASE_ID=
